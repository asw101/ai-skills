package local:github;

interface api {
    record user-info {
        login: string,
        id: u64,
        name: option<string>,
        bio: option<string>,
        public-repos: u32,
        followers: u32,
        following: u32,
        html-url: string,
    }

    record repo-info {
        full-name: string,
        description: option<string>,
        stargazers-count: u32,
        forks-count: u32,
        language: option<string>,
        default-branch: string,
        html-url: string,
    }

    /// Fetch basic details for a GitHub user.
    /// `token` is an optional bearer credential — pass none for unauthenticated calls.
    get-user: async func(login: string, token: option<string>) -> result<user-info, string>;

    /// Fetch basic details for a GitHub repository.
    get-repo: async func(owner: string, repo: string, token: option<string>) -> result<repo-info, string>;
}

world github {
    import wasi:http/client@0.3.0-rc-2026-03-15;
    import wasi:http/types@0.3.0-rc-2026-03-15;
    export api;
}
