# Component build recipes (run outside the sandbox to access tool caches).
#
# Each toolchain produces a .wasm at its natural location; the recipes here
# own the convention of copying it to components/bin/<name>.wasm. If you
# change the convention, change it once here.

# List available recipes
default:
    @just --list

# Build all components in this repo
build-all: build-csv-groupby build-stock-ticker build-tech-ticker build-wasip3-demo

# Build the csv-groupby component (Rust / cargo build → wasi p2 with embedded WIT)
build-csv-groupby:
    #!/usr/bin/env bash
    set -euo pipefail
    cd csv-groupby
    cargo build --release --target wasm32-wasip2
    cd ..
    mkdir -p bin
    cp csv-groupby/target/wasm32-wasip2/release/csv_groupby.wasm bin/csv-groupby.wasm
    wasm-tools validate bin/csv-groupby.wasm
    echo "✓ bin/csv-groupby.wasm $(ls -lh bin/csv-groupby.wasm | awk '{print $5}')"

# Build the stock-ticker component (Go / TinyGo → wasi p2 with embedded WIT)
build-stock-ticker:
    #!/usr/bin/env bash
    set -euo pipefail
    cd stock-ticker
    tinygo build \
        -target wasip2 \
        -opt=2 \
        --wit-package ./wit \
        --wit-world stock-ticker \
        -o stock-ticker.wasm \
        main.go
    cd ..
    mkdir -p bin
    cp stock-ticker/stock-ticker.wasm bin/stock-ticker.wasm
    wasm-tools validate bin/stock-ticker.wasm
    echo "✓ bin/stock-ticker.wasm $(ls -lh bin/stock-ticker.wasm | awk '{print $5}')"

# Build the tech-ticker component (Rust / cargo build → wasi p2 with embedded WIT)
build-tech-ticker:
    #!/usr/bin/env bash
    set -euo pipefail
    cd tech-ticker
    cargo build --release --target wasm32-wasip2
    cd ..
    mkdir -p bin
    cp tech-ticker/target/wasm32-wasip2/release/tech_ticker.wasm bin/tech-ticker.wasm
    wasm-tools validate bin/tech-ticker.wasm
    echo "✓ bin/tech-ticker.wasm $(ls -lh bin/tech-ticker.wasm | awk '{print $5}')"

# Build the wasip3-demo component (Rust / wit-bindgen macro + adapter → wasi p3)
# Flow B pattern (see .agents/skills/wasm-build/scripts/rust.md): build a
# wasm32-wasip1 core module, wrap with wasm-tools component new --adapt.
build-wasip3-demo:
    #!/usr/bin/env bash
    set -euo pipefail
    # 1. Locate or download the reactor adapter.
    ADAPTER="$PWD/.adapters/wasi_snapshot_preview1.reactor.wasm"
    if [ ! -f "$ADAPTER" ]; then
        mkdir -p .adapters
        echo "Downloading wasi_snapshot_preview1.reactor.wasm (wasmtime 44.0.0)..."
        curl -fsSL -o "$ADAPTER" \
            "https://github.com/bytecodealliance/wasmtime/releases/download/v44.0.0/wasi_snapshot_preview1.reactor.wasm"
    fi
    # 2. Compile a core wasip1 module via the wit-bindgen macro.
    cd wasip3-demo
    cargo build --release --target wasm32-wasip1
    # 3. Wrap it as a Component using the reactor adapter.
    cd ..
    mkdir -p bin
    wasm-tools component new \
        wasip3-demo/target/wasm32-wasip1/release/wasip3_demo.wasm \
        --adapt "wasi_snapshot_preview1=$ADAPTER" \
        --skip-validation \
        -o bin/wasip3-demo.wasm
    wasm-tools validate --features all bin/wasip3-demo.wasm
    echo "✓ bin/wasip3-demo.wasm $(ls -lh bin/wasip3-demo.wasm | awk '{print $5}')"

# Validate every .wasm under bin/ and print its exported WIT
validate-all:
    #!/usr/bin/env bash
    set -euo pipefail
    for w in bin/*.wasm; do
        echo "=== $w ==="
        # `--features all` so async/p3 components (e.g. wasip3-demo) validate.
        wasm-tools validate --features all "$w"
        size=$(ls -lh "$w" | awk '{print $5}')
        echo "  validated · $size"
        if wit_out=$(wasm-tools component wit "$w" 2>&1); then
            echo "$wit_out" | head -5
        else
            echo "  (component wit not extractable: $(echo "$wit_out" | head -1))"
        fi
        echo ""
    done

# Test the csv-groupby component with wasmtime
test-csv-groupby:
    #!/usr/bin/env bash
    set -euo pipefail
    wasmtime run --invoke 'execute-group-by({csv-data: "a,b\n1,2\n1,3", group-columns: ["a"], aggregations: [{column: "b", operation: sum, alias: none}], has-header: true})' bin/csv-groupby.wasm

# Test the stock-ticker component with wasmtime
test-stock-ticker:
    #!/usr/bin/env bash
    set -euo pipefail
    wasmtime run --invoke 'get-price(msft)' bin/stock-ticker.wasm

# Test the tech-ticker component with wasmtime
test-tech-ticker:
    #!/usr/bin/env bash
    set -euo pipefail
    wasmtime run --invoke 'ping()' bin/tech-ticker.wasm
    wasmtime run --invoke 'random-string(10)' bin/tech-ticker.wasm

# Test the wasip3-demo component with wasmtime (requires -Sp3 -Wcomponent-model-async)
test-wasip3-demo:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "--- sync (p2-compatible export) ---"
    wasmtime run -Sp3 -Wcomponent-model-async --invoke 'greet("p2")' bin/wasip3-demo.wasm
    echo "--- async (p3-only export) ---"
    wasmtime run -Sp3 -Wcomponent-model-async --invoke 'greet-async("p3")' bin/wasip3-demo.wasm

# Test all components
test-all: test-csv-groupby test-stock-ticker test-tech-ticker test-wasip3-demo

# Remove built artifacts
clean:
    #!/usr/bin/env bash
    set -euo pipefail
    rm -rf bin/*.wasm
    rm -rf csv-groupby/target tech-ticker/target wasip3-demo/target stock-ticker/stock-ticker.wasm
    echo "✓ cleaned"
