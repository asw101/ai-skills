# Component build recipes (run outside the sandbox to access tool caches).
#
# Each toolchain produces a .wasm at its natural location; the recipes here
# own the convention of copying it to components/bin/<name>.wasm. If you
# change the convention, change it once here.

# List available recipes
default:
    @just --list

# Build all components in this repo
build-all: build-csv-groupby build-stock-ticker build-tech-ticker build-wasip3-demo

# Build the csv-groupby component (Rust / cargo build → wasi p2 with embedded WIT)
build-csv-groupby:
    #!/usr/bin/env bash
    set -euo pipefail
    cd csv-groupby
    cargo build --release --target wasm32-wasip2
    cd ..
    mkdir -p bin
    cp csv-groupby/target/wasm32-wasip2/release/csv_groupby.wasm bin/csv-groupby.wasm
    wasm-tools validate bin/csv-groupby.wasm
    echo "✓ bin/csv-groupby.wasm $(ls -lh bin/csv-groupby.wasm | awk '{print $5}')"

# Build the stock-ticker component (Go / TinyGo → wasi p2 with embedded WIT)
build-stock-ticker:
    #!/usr/bin/env bash
    set -euo pipefail
    cd stock-ticker
    tinygo build \
        -target wasip2 \
        -opt=2 \
        --wit-package ./wit \
        --wit-world stock-ticker \
        -o stock-ticker.wasm \
        main.go
    cd ..
    mkdir -p bin
    cp stock-ticker/stock-ticker.wasm bin/stock-ticker.wasm
    wasm-tools validate bin/stock-ticker.wasm
    echo "✓ bin/stock-ticker.wasm $(ls -lh bin/stock-ticker.wasm | awk '{print $5}')"

# Build the tech-ticker component (Rust / cargo build → wasi p2 with embedded WIT)
build-tech-ticker:
    #!/usr/bin/env bash
    set -euo pipefail
    cd tech-ticker
    cargo build --release --target wasm32-wasip2
    cd ..
    mkdir -p bin
    cp tech-ticker/target/wasm32-wasip2/release/tech_ticker.wasm bin/tech-ticker.wasm
    wasm-tools validate bin/tech-ticker.wasm
    echo "✓ bin/tech-ticker.wasm $(ls -lh bin/tech-ticker.wasm | awk '{print $5}')"

# Build the wasip3-demo component (Rust / wit-bindgen macro + adapter → wasi p3)
# Flow B pattern (see .agents/skills/wasm-build/scripts/rust.md): build a
# wasm32-wasip1 core module, wrap with wasm-tools component new --adapt.
build-wasip3-demo:
    #!/usr/bin/env bash
    set -euo pipefail
    # 1. Locate or download the reactor adapter.
    ADAPTER="$PWD/.adapters/wasi_snapshot_preview1.reactor.wasm"
    if [ ! -f "$ADAPTER" ]; then
        mkdir -p .adapters
        echo "Downloading wasi_snapshot_preview1.reactor.wasm (wasmtime 44.0.0)..."
        curl -fsSL -o "$ADAPTER" \
            "https://github.com/bytecodealliance/wasmtime/releases/download/v44.0.0/wasi_snapshot_preview1.reactor.wasm"
    fi
    # 2. Compile a core wasip1 module via the wit-bindgen macro.
    cd wasip3-demo
    cargo build --release --target wasm32-wasip1
    # 3. Wrap it as a Component using the reactor adapter.
    cd ..
    mkdir -p bin
    wasm-tools component new \
        wasip3-demo/target/wasm32-wasip1/release/wasip3_demo.wasm \
        --adapt "wasi_snapshot_preview1=$ADAPTER" \
        --skip-validation \
        -o bin/wasip3-demo.wasm
    wasm-tools validate --features all bin/wasip3-demo.wasm
    echo "✓ bin/wasip3-demo.wasm $(ls -lh bin/wasip3-demo.wasm | awk '{print $5}')"

# Validate every .wasm under bin/ and print its exported WIT
validate-all:
    #!/usr/bin/env bash
    set -euo pipefail
    for w in bin/*.wasm; do
        echo "=== $w ==="
        # `--features all` so async/p3 components (e.g. wasip3-demo) validate.
        wasm-tools validate --features all "$w"
        size=$(ls -lh "$w" | awk '{print $5}')
        echo "  validated · $size"
        if wit_out=$(wasm-tools component wit "$w" 2>&1); then
            echo "$wit_out" | head -5
        else
            echo "  (component wit not extractable: $(echo "$wit_out" | head -1))"
        fi
        echo ""
    done

# Test the csv-groupby component with wasmtime
test-csv-groupby:
    #!/usr/bin/env bash
    set -euo pipefail
    wasmtime run --invoke 'execute-group-by({csv-data: "a,b\n1,2\n1,3", group-columns: ["a"], aggregations: [{column: "b", operation: sum, alias: none}], has-header: true})' bin/csv-groupby.wasm

# Test the stock-ticker component with wasmtime
test-stock-ticker:
    #!/usr/bin/env bash
    set -euo pipefail
    wasmtime run --invoke 'get-price(msft)' bin/stock-ticker.wasm

# Test the tech-ticker component with wasmtime
test-tech-ticker:
    #!/usr/bin/env bash
    set -euo pipefail
    wasmtime run --invoke 'ping()' bin/tech-ticker.wasm
    wasmtime run --invoke 'random-string(10)' bin/tech-ticker.wasm

# Test the wasip3-demo component with wasmtime (requires -Sp3 -Wcomponent-model-async)
test-wasip3-demo:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "--- sync (p2-compatible export) ---"
    wasmtime run -Sp3 -Wcomponent-model-async --invoke 'greet("p2")' bin/wasip3-demo.wasm
    echo "--- async (p3-only export) ---"
    wasmtime run -Sp3 -Wcomponent-model-async --invoke 'greet-async("p3")' bin/wasip3-demo.wasm

# === github (multi-language: rs, py, js, go) ============================
# Built with the wasm-build-multi skill. All four implementations export
# the same local:github/api world (get-user, get-repo) and import
# wasi:http/outgoing-handler@0.2.6 for the actual API calls. Run with
# `wasmtime run -S http=allow-private-network --invoke ...` to test.

# Build all available github implementations (skips missing dirs)
build-all-github: build-github-rs build-github-js build-github-go build-github-py

build-github-rs:
    #!/usr/bin/env bash
    set -euo pipefail
    [ -d github-rs ] || { echo "⚠ github-rs not found, skipping"; exit 0; }
    cd github-rs
    cargo build --release --target wasm32-wasip2
    cd ..
    mkdir -p bin
    cp github-rs/target/wasm32-wasip2/release/github_rs.wasm bin/github-rs.wasm
    wasm-tools validate --features all bin/github-rs.wasm
    echo "✓ bin/github-rs.wasm $(ls -lh bin/github-rs.wasm | awk '{print $5}')"

build-github-js:
    #!/usr/bin/env bash
    set -euo pipefail
    [ -d github-js ] || { echo "⚠ github-js not found, skipping"; exit 0; }
    cd github-js
    [ -d node_modules ] || npm install --silent
    npx jco componentize src/index.js --wit wit -o ../bin/github-js.wasm
    cd ..
    wasm-tools validate bin/github-js.wasm
    echo "✓ bin/github-js.wasm $(ls -lh bin/github-js.wasm | awk '{print $5}')"

build-github-go:
    #!/usr/bin/env bash
    set -euo pipefail
    [ -d github-go ] || { echo "⚠ github-go not found, skipping"; exit 0; }
    cd github-go
    go generate ./...
    tinygo build -target=wasip2 --wit-package wit --wit-world github -o ../bin/github-go.wasm .
    cd ..
    wasm-tools validate bin/github-go.wasm
    echo "✓ bin/github-go.wasm $(ls -lh bin/github-go.wasm | awk '{print $5}')"

build-github-py:
    #!/usr/bin/env bash
    set -euo pipefail
    [ -d github-py ] || { echo "⚠ github-py not found, skipping"; exit 0; }
    cd github-py
    rm -rf wit_world componentize_py_async_support componentize_py_runtime.pyi componentize_py_types.py poll_loop.py
    componentize-py -d wit -w github bindings .
    componentize-py -d wit -w github componentize app -o ../bin/github-py.wasm
    cd ..
    wasm-tools validate --features all bin/github-py.wasm
    echo "✓ bin/github-py.wasm $(ls -lh bin/github-py.wasm | awk '{print $5}')"

# Validate every github-*.wasm and print its exported WIT
validate-github:
    #!/usr/bin/env bash
    set -euo pipefail
    for w in bin/github-*.wasm; do
        [ -f "$w" ] || continue
        echo "=== $w ==="
        wasm-tools validate --features all "$w"
        echo "  validated · $(ls -lh "$w" | awk '{print $5}')"
        wasm-tools component wit "$w" 2>/dev/null | head -3 || echo "  (no extractable WIT)"
        echo ""
    done

# Test the github component with wasmtime.
# Defaults to rs; override LANG to switch (e.g. LANG=js just test-github).
# Each language uses different runtime flags depending on its WASI version:
#   rs, py  -> WASI 0.3 (-Sp3 -Wcomponent-model-async)
#   js, go  -> WASI 0.2 (no extra flags)
# All four still need -S http to allow outgoing HTTP.
test-github lang="rs":
    #!/usr/bin/env bash
    set -euo pipefail
    case "{{lang}}" in
        rs|py) flags="-Sp3 -Shttp -Wcomponent-model-async";;
        js|go) flags="-Shttp";;
        *) echo "unknown lang: {{lang}} (use rs|py|js|go)"; exit 1;;
    esac
    set -x
    wasmtime run $flags --invoke 'get-user("octocat", none)' bin/github-{{lang}}.wasm
    wasmtime run $flags --invoke 'get-repo("octocat", "Hello-World", none)' bin/github-{{lang}}.wasm

# Test every github-*.wasm in turn (rs+py via p3, js+go via p2).
test-all-github: (test-github "rs") (test-github "go") (test-github "js") (test-github "py")

# Test all components
test-all: test-csv-groupby test-stock-ticker test-tech-ticker test-wasip3-demo

# Remove built artifacts
clean:
    #!/usr/bin/env bash
    set -euo pipefail
    rm -rf bin/*.wasm
    rm -rf csv-groupby/target tech-ticker/target wasip3-demo/target stock-ticker/stock-ticker.wasm github-rs/target github-go/gen github-py/wit_world github-py/poll_loop.py github-py/componentize_py_async_support github-py/componentize_py_runtime.pyi github-py/componentize_py_types.py github-js/node_modules
    echo "✓ cleaned"
